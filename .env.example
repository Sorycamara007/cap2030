# Clé API Anthropic — ne pas committer la vraie clé
ANTHROPIC_API_KEY=sk-ant-...

# Mot de passe d'accès à l'application (login screen)
APP_PASSWORD=changez-moi

# Resend — envoi automatique du rapport par email après génération
RESEND_API_KEY=re_...
REPORT_EMAIL_TO=destinataire@example.com
# Free tier sans domaine vérifié : utiliser onboarding@resend.dev
REPORT_EMAIL_FROM=CAP 2030 <onboarding@resend.dev>

# Port du serveur API en dev local (optionnel, défaut 3001)
PORT=3001
